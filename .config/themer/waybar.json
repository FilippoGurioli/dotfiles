{
  "position": "top",
  "modules-left": ["custom/distro-icon", "hyprland/workspaces"],
  "modules-center": ["hyprland/window"],
  "modules-right": ["custom/recorder", "cpu", "memory", "custom/updates", "pulseaudio", "backlight", "bluetooth", "battery", "power-profiles-daemon", "network", "clock"],
  "custom/distro-icon": {
    "format": "يîت",
    "interval": 3600
  },
  "hyprland/window": {
    "format": "{class}" 
  },
  "custom/updates": {
    "exec": "~/.config/waybar/scripts/updates.sh",
    "interval": 60,
    "return-type": "json",
    "format": "{}"
  },
  "clock": {
    "format": "{:%H:%M %d/%m}",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
