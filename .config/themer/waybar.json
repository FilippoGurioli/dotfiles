    "format-charging": "يçخ {capacity}%",
    "format-plugged": "يçخ {capacity}%",
    "format-alt": "{icon} {time}",
    "format-full": "ي  {capacity}%",
    "format-icons": ["يë", "يëâ", "يëé", "يë", "يë"],
