      "on-click": "pavucontrol"
  },
  "backlight": {
    "format": "{icon}",
    "format-icons": {
      "default": ["ٍ░î╢", "ٍ▒ر", "ٍ▒ر", "ٍ▒ر", "ٍ▒رّ", "ٍ▒رْ", "ٍ▒رô", "ٍ▒ر¤", "ٍ▒رـ", "ٍ▒رû", "ٍ░ؤذ"]
    },
    "tooltip-format": "{percent}%"
  },
  "bluetooth": {
    "format": "يè¤",
    "format-disabled": "ٍ░é▓",
    "format-off": "ٍ░é▓",
    "format-on": "يè¤",
    "format-connected": "يè¤ {num_connections}",
    "format-connected-battery": "يè¤{num_connections} {device_battery_percentage}%",
    "tooltip-format": "{controller_alias}\t{controller_address}\n\n{num_connections} connected",
